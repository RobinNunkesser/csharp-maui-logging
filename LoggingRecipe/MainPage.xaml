<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:LoggingRecipe.ViewModels;assembly=LoggingRecipe.ViewModels"
             x:Class="LoggingRecipe.MainPage"
             x:DataType="viewModels:MainPageViewModel">

    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,0"
            VerticalOptions="Center">

            <Image
                Source="dotnet_bot.png"
                HeightRequest="200"
                HorizontalOptions="Center" />

            <Label
                Text="Logging mit MVVM"
                FontSize="32"
                HorizontalOptions="Center" />

            <Label
                Text="{Binding LifecycleState}"
                HorizontalOptions="Center"/>

            <Entry
                Placeholder="Log-Nachricht"
                Text="{Binding Message}" />

            <Button
                Text="Info loggen"
                Command="{Binding LogInfoCommand}" />

            <Label
                Text="{Binding LastLog}"
                FontSize="18"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

